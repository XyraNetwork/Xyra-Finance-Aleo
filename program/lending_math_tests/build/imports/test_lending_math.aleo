program test_lending_math.aleo;

function test_weighted_known:
    cast 10000000u64 into r0 as u128;
    cast 1000000u64 into r1 as u128;
    mul r0 r1 into r2;
    cast 7500u64 into r3 as u128;
    is.eq r3 0u128 into r4;
    div 340282366920938463463374607431768211455u128 r3 into r5;
    lte r2 r5 into r6;
    or r4 r6 into r7;
    mul r2 r3 into r8;
    div r8 10000000000u128 into r9;
    cast r9 into r10 as u64;
    div r2 1000000u128 into r11;
    mul r11 r3 into r12;
    div r12 10000u128 into r13;
    cast r13 into r14 as u64;
    ternary r7 r10 r14 into r15;
    is.eq r15 7500000u64 into r16;
    assert.eq r16 true;

function test_health_cross_ok:
    cast 20000000u64 into r0 as u128;
    cast 1000000u64 into r1 as u128;
    mul r0 r1 into r2;
    cast 7500u64 into r3 as u128;
    is.eq r3 0u128 into r4;
    div 340282366920938463463374607431768211455u128 r3 into r5;
    lte r2 r5 into r6;
    or r4 r6 into r7;
    mul r2 r3 into r8;
    div r8 10000000000u128 into r9;
    cast r9 into r10 as u64;
    div r2 1000000u128 into r11;
    mul r11 r3 into r12;
    div r12 10000u128 into r13;
    cast r13 into r14 as u64;
    ternary r7 r10 r14 into r15;
    cast 10000000u64 into r16 as u128;
    cast 1000000u64 into r17 as u128;
    mul r16 r17 into r18;
    cast 8500u64 into r19 as u128;
    is.eq r19 0u128 into r20;
    div 340282366920938463463374607431768211455u128 r19 into r21;
    lte r18 r21 into r22;
    or r20 r22 into r23;
    mul r18 r19 into r24;
    div r24 10000000000u128 into r25;
    cast r25 into r26 as u64;
    div r18 1000000u128 into r27;
    mul r27 r19 into r28;
    div r28 10000u128 into r29;
    cast r29 into r30 as u64;
    ternary r23 r26 r30 into r31;
    cast 0u64 into r32 as u128;
    cast 1000000u64 into r33 as u128;
    mul r32 r33 into r34;
    cast 8500u64 into r35 as u128;
    is.eq r35 0u128 into r36;
    div 340282366920938463463374607431768211455u128 r35 into r37;
    lte r34 r37 into r38;
    or r36 r38 into r39;
    mul r34 r35 into r40;
    div r40 10000000000u128 into r41;
    cast r41 into r42 as u64;
    div r34 1000000u128 into r43;
    mul r43 r35 into r44;
    div r44 10000u128 into r45;
    cast r45 into r46 as u64;
    ternary r39 r42 r46 into r47;
    cast r15 into r48 as u128;
    cast r31 into r49 as u128;
    add r48 r49 into r50;
    cast r47 into r51 as u128;
    add r50 r51 into r52;
    cast 0u64 into r53 as u128;
    cast 1000000u64 into r54 as u128;
    mul r53 r54 into r55;
    div r55 1000000u128 into r56;
    cast r56 into r57 as u64;
    cast 0u64 into r58 as u128;
    cast 1000000u64 into r59 as u128;
    mul r58 r59 into r60;
    div r60 1000000u128 into r61;
    cast r61 into r62 as u64;
    cast 0u64 into r63 as u128;
    cast 1000000u64 into r64 as u128;
    mul r63 r64 into r65;
    div r65 1000000u128 into r66;
    cast r66 into r67 as u64;
    cast r57 into r68 as u128;
    cast r62 into r69 as u128;
    add r68 r69 into r70;
    cast r67 into r71 as u128;
    add r70 r71 into r72;
    cast 10000000u64 into r73 as u128;
    cast 1000000u64 into r74 as u128;
    mul r73 r74 into r75;
    div r75 1000000u128 into r76;
    cast r76 into r77 as u64;
    cast r77 into r78 as u128;
    add r72 r78 into r79;
    lte r79 r52 into r80;
    assert.eq r80 true;

function test_health_over_fail:
    cast 1000000u64 into r0 as u128;
    cast 1000000u64 into r1 as u128;
    mul r0 r1 into r2;
    cast 7500u64 into r3 as u128;
    is.eq r3 0u128 into r4;
    div 340282366920938463463374607431768211455u128 r3 into r5;
    lte r2 r5 into r6;
    or r4 r6 into r7;
    mul r2 r3 into r8;
    div r8 10000000000u128 into r9;
    cast r9 into r10 as u64;
    div r2 1000000u128 into r11;
    mul r11 r3 into r12;
    div r12 10000u128 into r13;
    cast r13 into r14 as u64;
    ternary r7 r10 r14 into r15;
    cast r15 into r16 as u128;
    cast 1000000u64 into r17 as u128;
    add 0u128 r17 into r18;
    lte r18 r16 into r19;
    not r19 into r20;
    assert.eq r20 true;

constructor:
    assert.eq edition 0u16;
